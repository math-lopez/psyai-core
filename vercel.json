{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": null,
  "rewrites": [
    {
      "source": "/docs",
      "destination": "/api/docs"
    },
    {
      "source": "/docs/(.*)",
      "destination": "/api/docs/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/$1"
    }
  ]
}
