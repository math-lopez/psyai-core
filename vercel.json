{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/v1/internal/run-transfers",
      "schedule": "* 11 * * *"
    },
    {
      "path": "/cron-test",
      "schedule": "* 11 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/docs",
      "destination": "/api?path=docs"
    },
    {
      "source": "/docs/:path*",
      "destination": "/api?path=docs&path=:path*"
    },
    {
      "source": "/v1/:path*",
      "destination": "/api?path=v1&path=:path*"
    },
    {
      "source": "/health",
      "destination": "/api?path=health"
    },
    {
      "source": "/",
      "destination": "/api"
    }
  ]
}
