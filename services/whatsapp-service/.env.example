# URL pública do serviço no Railway (preencher após o deploy)
SERVER_URL=https://seu-servico.up.railway.app

# Chave global de autenticação da API — gere uma string aleatória forte
# Ex: openssl rand -hex 32
AUTHENTICATION_API_KEY=sua_chave_secreta_aqui

# Tipo de autenticação (não alterar)
AUTHENTICATION_TYPE=apikey

# Configuração de instâncias
DEL_INSTANCE=false

# Banco de dados para persistência das sessões WhatsApp
# Use a URL do PostgreSQL do Railway ou Supabase
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://user:password@host:5432/dbname

# Tabelas que serão criadas automaticamente (não alterar)
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_MESSAGE_UPDATE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false

# Logs (info, error, warn, debug)
LOG_LEVEL=info
LOG_COLOR=false

# Não alterar
QRCODE_LIMIT=30
